<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" parallel="methods" thread-count="2">
  <parameter name="browser" value="chrome"/>
  <parameter name="env" value="dev"/>
  <test name="Smoke Tests">
    <classes>
      <class name="com.saucedemo.tests.LoginTest">
        <methods>
          <include name="testLoginSuccess"/>
          <include name="testLoginWithWrongPassword"/>
          <include name="testLoginIntentionalFail"/>
        </methods>
      </class>
    </classes>
  </test>
</suite>
